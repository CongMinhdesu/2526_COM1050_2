class Solution:
    def findMaxConsecutiveOnes(self, nums: List[int]):
        cnt = 0
        max = 0
        if len(nums) == 1:
            if nums[0] == 0:
                return 0
            else:
                return 1
        else:
            if nums[0] == 1 or nums[len(nums)-1] == 1:
                cnt = 1
                max = 1
            for i in range (1,len(nums)):
                if nums[i] == 1 and nums[i-1] == 1:
                    if cnt == 0:
                        cnt = 1
                    cnt = cnt + 1
                    if cnt > max:
                        max = cnt
                else:
                    cnt = 0
            return max
